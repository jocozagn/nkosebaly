# Copiez ce fichier vers .env et remplissez les valeurs.
# Ne commitez JAMAIS le fichier .env réel.

NODE_ENV=production
NEXT_PUBLIC_WEB_VERSION=1.1.2

# URL publique du site (HTTPS en production)
NEXT_PUBLIC_WEB_URL=https://votre-domaine.com
NEXT_PUBLIC_API_URL=https://votre-domaine.com

# Marque
NEXT_PUBLIC_WEB_NAME=Karamoo Sêebaly
NEXT_PUBLIC_LOADER_COLOR=#7D4E2D
NEXT_PUBLIC_TITLE=Karamoo Sêebaly - Apprentissage du N'ko Mandingue
NEXT_PUBLIC_DESCRIPTION=Plateforme d'apprentissage du N'ko Mandingue.
NEXT_PUBLIC_KEYWORDS=N'ko,Mandingue,Karamoo Sêebaly

# SEO / démo (laisser tel quel sauf besoin spécifique)
NEXT_PUBLIC_SEO=true
NEXT_PUBLIC_END_POINT=api
NEXT_PUBLIC_DEMO=false
NEXT_PUBLIC_LOAD_MIN=5

# IMPORTANT: false en production (désactive le bypass QR de test)
NEXT_PUBLIC_DEV_BYPASS=false

# Stockage données : json (défaut) ou postgres (phase Scale)
DATA_STORE=json
DATABASE_URL=postgresql://nko:nko_change_me@127.0.0.1:5432/nko

# Admin — identifiants + secret de signature des sessions
ADMIN_EMAIL=admin@votre-domaine.com
ADMIN_PASSWORD=changez-ce-mot-de-passe
ADMIN_SESSION_SECRET=generez-une-chaine-aleatoire-longue

# Djomy (paiement certificats)
DJOMY_CLIENT_ID=
DJOMY_CLIENT_SECRET=
DJOMY_PARTNER_DOMAIN=
# Production: https://api.djomy.africa
# Sandbox: https://sandbox-api.djomy.africa
DJOMY_BASE_URL=https://api.djomy.africa

# Firebase (legacy — non utilisé par le flux N'ko actuel)
NEXT_PUBLIC_VAPID_KEY=
NEXT_PUBLIC_API_KEY=
NEXT_PUBLIC_AUTH_DOMAIN=
NEXT_PUBLIC_PROJECT_ID=
NEXT_PUBLIC_STORAGE_BUCKET=
NEXT_PUBLIC_MESSAGING_SENDER_ID=
NEXT_PUBLIC_APP_ID=
NEXT_PUBLIC_MEASUREMENT_ID=

NEXT_PUBLIC_DEFAULT_COUNTRY_CODE=gn
NEXT_PUBLIC_COUNTRY_DIAL_CODE=224
